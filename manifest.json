{
  "manifest_version": 3,
  "browser_specific_settings": {
    "gecko": {
      "id": "grinkers@grinkers.net",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "name": "YubTub",
  "version": "0.1.0",
  "description": "Makes YouTube into YubTub.",
  "permissions": ["declarativeNetRequest"],
  "host_permissions": ["*://*.youtube.com/*"],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "shorts_redirect",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "content_scripts": [
    {
      "matches": ["*://www.youtube.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_end"
    }
  ],
  "icons": {
    "48": "icons/icon.svg",
    "96": "icons/icon.svg"
  }
}
